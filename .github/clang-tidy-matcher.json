{
  "problemMatcher": [
    {
      "owner": "clang-tidy",
      "pattern": [
        {
          "regexp": "^([^:\\s][^:]*):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*?)(?:\\s\\[(.+)\\])?$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5,
          "code": 6
        }
      ]
    }
  ]
}
